{
  "name": "reviuah",
  "version": "1.0.10",
  "description": "AI-powered Git diff reviewer CLI — staged, branch vs base, CI-friendly",
  "license": "MIT",
  "author": "rsuregar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rsuregar/reviewah.git"
  },
  "homepage": "https://github.com/rsuregar/reviewah#readme",
  "bugs": {
    "url": "https://github.com/rsuregar/reviewah/issues"
  },
  "keywords": [
    "cli",
    "git",
    "diff",
    "code-review",
    "ai",
    "llm",
    "openai",
    "pre-commit",
    "ci"
  ],
  "type": "module",
  "bin": {
    "reviuah": "dist/cli.js",
    "reviewah": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit",
    "test": "yarn build && node --test dist/lib/check-update.test.js dist/ui/update-prompt.test.js",
    "start": "node dist/cli.js",
    "version:patch": "node scripts/bump-version.mjs patch",
    "version:minor": "node scripts/bump-version.mjs minor",
    "version:major": "node scripts/bump-version.mjs major",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "blessed": "^0.1.81",
    "commander": "^12.1.0",
    "execa": "^9.3.1",
    "openai": "^4.67.3",
    "semver": "^7.6.3"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.27",
    "@types/node": "^25.3.3",
    "@types/semver": "^7.5.0",
    "typescript": "^5.6.3"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
